{
  "name": "@brucestudios/awesome-utils",
  "version": "1.0.0",
  "description": "A collection of useful utility functions for everyday development tasks",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "version": "npm run build && git add -A dist",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "utility",
    "helpers",
    "typescript",
    "javascript",
    "utils",
    "functions"
  ],
  "author": "Bruce Studios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brucestudios/awesome-utils.git"
  },
  "bugs": {
    "url": "https://github.com/brucestudios/awesome-utils/issues"
  },
  "homepage": "https://github.com/brucestudios/awesome-utils#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "rollup": "^3.0.0",
    "rollup-plugin-typescript2": "^0.35.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}